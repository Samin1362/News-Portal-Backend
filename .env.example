# --- Phase 1 (required) ---
NODE_ENV=development
PORT=5001
CORS_ORIGINS=http://localhost:3000

# Mongo connection — provide either URI (Atlas-style) or MONGODB_URI (whichever you prefer)
URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=Cluster0
# DB_USER and DB_PASS are optional — already embedded in URI; useful for logging only
DB_USER=
DB_PASS=
# Database name (defaults to news_portal if omitted)
DB_NAME=news_portal

# --- Phase 2 (Firebase Admin) ---
# Option A: path to a service-account JSON file (recommended for local dev)
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Option B: inline credentials via env (use this in production / hosted envs)
# FIREBASE_PROJECT_ID=news-portal-firebase-project
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@news-portal-firebase-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- Cross-cutting (defaults available) ---
RATE_LIMIT_GLOBAL_PER_MIN=300
COMMENTS_REQUIRE_APPROVAL=false
PUBLIC_BASE_URL=http://localhost:5000
